#!/bin/sh
#
# Wrapper for Node.js CLI Boilerplate

# Check whether Node.js is available on the system.
if ! command -v node >/dev/null 2>&1; then
    echo "No Node.js on the system" >&2
    exit 1
fi

# Get the path of current shell script.
cwd=$(dirname "$0")

# Get the directory of our PHP script.
libexec="${cwd}/../libexec"

# Run the PHP script and pass command-line arguments to it.
exec node "${libexec}/serpctl.js" "$@"